# Projet Supabase : Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Recommandé (nouveau format) — au moins une des deux clés « publiques » :
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Ancienne clé JWT (optionnel si publishable défini)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optionnel : URL publique du site (e-mails de confirmation, prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optionnel, serveur uniquement : scripts admin / tâches qui contournent RLS — ne jamais exposer au client
# SUPABASE_SERVICE_ROLE_KEY=
