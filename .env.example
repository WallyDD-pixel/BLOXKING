# Base PostgreSQL (serveur uniquement)
DATABASE_URL=postgresql://bloxking:CHANGE_ME@localhost:5432/bloxking
# Mettre à true si ton Postgres exige SSL (ex: certains hébergeurs managés)
DATABASE_SSL=false
# Connexions max du pool pg (défaut 12 — adapter selon RAM / max_connections Postgres)
DATABASE_POOL_MAX=12

# URL publique du site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# YouTube — lecteur live sur l'accueil uniquement (https://console.cloud.google.com)
# Créer une clé API, activer "YouTube Data API v3", quota ~100 unités / visite cache 60s
YOUTUBE_API_KEY=
# Handle de la chaîne sans @ (défaut warrenoff → @warrenoff)
YOUTUBE_CHANNEL_HANDLE=warrenoff

# Stockage local des preuves de litige (prod : créer le dossier sur le serveur)
# Dev sans variable : .data/dispute-evidence à la racine du projet
DISPUTE_EVIDENCE_DIR=/var/bloxking/dispute-evidence
# Taille max vidéo litige en octets (défaut 50 Mo = 52428800)
DISPUTE_VIDEO_MAX_BYTES=52428800

# E-mails (notifications litige, victoire/défaite) — serveur uniquement
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Gmail : même adresse que SMTP_USER (ou laisser vide, SMTP_USER sera utilisé)
# Ne pas définir DISPUTE_EMAIL_FROM avec une autre adresse sur Gmail
# DISPUTE_EMAIL_FROM=

# Présence « en ligne » admin (minutes sans activité = hors ligne)
# PRESENCE_ONLINE_MINUTES=5

# ── Vercel / prod : voir docs/deploy-vercel.md
# - DATABASE_URL doit pointer vers un Postgres reachable depuis Internet (Neon, etc.)
# - DATABASE_SSL=true souvent obligatoire (SSL)
# - NEXT_PUBLIC_SITE_URL=https://ton-domaine.vercel.app
# - Stockage DISPUTE sur disque = non durable sur serverless → migrer Blob/S3 pour les litiges
